    {
      "parameters": {
        "toolDescription": "Actualiza el estado de la orden. Usa IN_PROCESS al confirmar pago, CANCELLED para cancelar (requiere validación previa).",
        "method": "POST",
        "url": "={{ $env.APP_DOMAIN }}/api/webhooks/orders",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.WEBHOOK_SECRET }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ orderId: $fromAI('order_id', 'ID de la orden'), newStatus: $fromAI('new_status', 'IN_PROCESS, DELIVERED_STORE, DELIVERED_DELIVERY o CANCELLED') }) }}",
        "options": {}
      },
