    {
      "parameters": {
        "description": "Genera el link de seguimiento de la orden para enviarlo al cliente por WhatsApp.",
        "jsCode": "const orderId = $fromAI('order_id', 'ID de la orden');\nconst validationCode = $fromAI('validation_code', 'Código validador de la orden');\nconst domain = $env.APP_DOMAIN;\nconst link = `${domain}/order/${orderId}?token=${validationCode}`;\nreturn { \n  trackingLink: link, \n  message: `Puedes seguir tu pedido aquí: ${link}` \n};"
