    {
      "parameters": {
        "description": "Genera el link de seguimiento de la orden para el cliente.",
        "jsCode": "const orderId = $fromAI('order_id', 'ID de la orden');\nconst validationCode = $fromAI('validation_code', 'Código validador');\nconst domain = $env.APP_DOMAIN;\nif (!orderId || !validationCode) return { error: 'Se necesitan orderId y validationCode.' };\nconst link = `${domain}/order/${orderId}?token=${validationCode}`;\nreturn { trackingLink: link, message: `🔍 Sigue tu pedido aquí: ${link}` };"
      },
      "type": "@n8n/n8n-nodes-langchain.toolCode",
      "typeVersion": 1.3,
      "position": [
        -384,
        576
      ],
      "id": "5381868e-77b5-4794-a1d2-1f4830723e5f",
      "name": "send_tracking_link"
    },
    {
      "parameters": {
        "jsCode": "// ✅ ANTI-BAN: Procesar output del agente\n// 1. Detectar [SESIÓN_CERRADA]\n// 2. Calcular delay humanizado aleatorio\nconst rawOutput = $json.output || '';\nconst shouldClose = rawOutput.includes('[SESIÓN_CERRADA]');\nconst cleanText = rawOutput.replace('[SESIÓN_CERRADA]', '').trim();\n\nconst minMs = parseInt($env.WA_TYPING_MIN_S || '1') * 1000;\nconst maxMs = parseInt($env.WA_TYPING_MAX_S || '4') * 1000;\nconst delay = Math.floor(Math.random() * (maxMs - minMs) + minMs);\n\nconst phone = $('When Executed by Another Workflow').first().json.phone;\nconst sessionData = $('When Executed by Another Workflow').first().json.sessionData || {};\n\nreturn [{ json: { cleanText, shouldClose, phone, delay, sessionData, orderId: sessionData.orderId } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -624,
        -16
      ],
      "id": "72742fd1-5912-402a-a15f-25d70e12f8f0",
      "name": "Procesar Output del Agente (Code)"
