      "parameters": {
        "jsCode": "// Actualizar el status en la sesión Redis si existe\nconst existingValue = $json.value;\nconst newStatus = $('wf3-node-05-send-wa').first().json.newStatus;\nconst phone = $('wf3-node-05-send-wa').first().json.phone;\n\nif (!existingValue) {\n  // No hay sesión, simplemente respond OK\n  return [{ json: { updated: false, reason: 'No session found for this phone', phone, newStatus } }];\n}\n\ntry {\n  const session = JSON.parse(existingValue);\n  session.status = newStatus;\n  return [{ json: { updated: true, updatedSession: JSON.stringify(session), phone, newStatus } }];\n} catch (e) {\n  return [{ json: { updated: false, reason: 'Failed to parse session JSON', phone, newStatus } }];\n}"
      },
