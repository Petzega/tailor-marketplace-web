        "jsCode": "// 🔐 Validar el Bearer token que envía el backend Next.js\nconst authHeader = $json.headers['authorization'] || '';\nconst expectedSecret = $env.WEBHOOK_SECRET || '';\n\nif (!expectedSecret) {\n  throw new Error('WEBHOOK_SECRET env variable is not configured in n8n');\n}\n\nif (authHeader !== `Bearer ${expectedSecret}`) {\n  throw new Error('Unauthorized: Invalid webhook secret');\n}\n\n// Validar que vengan los campos requeridos\nconst { orderId, newStatus, customerPhone, customerName, total, previousStatus } = $json.body;\n\nif (!orderId || !newStatus || !customerPhone) {\n  throw new Error(`Missing required fields: orderId=${orderId}, newStatus=${newStatus}, customerPhone=${customerPhone}`);\n}\n\n// Pasar los datos validados al siguiente nodo\nreturn [{ json: { orderId, newStatus, previousStatus: previousStatus || 'PENDING', customerPhone, customerName: customerName || 'Cliente', total: total || 0 } }];"
      },
