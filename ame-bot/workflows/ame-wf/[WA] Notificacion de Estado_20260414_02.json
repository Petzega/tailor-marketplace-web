    {
      "parameters": {
        "jsCode": "// 🕐 ANTI-BAN: Calcular delay humanizado para notificación\nconst minMs = parseInt($env.WA_TYPING_MIN_S || '1') * 1000;\nconst maxMs = parseInt($env.WA_TYPING_MAX_S || '4') * 1000;\nconst delay = Math.floor(Math.random() * (maxMs - minMs) + minMs);\nreturn [{ json: { ...$json, delay } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [912, 0],
      "id": "wf3-delay-001",
      "name": "Calcular Delay Humanizado (Code)"
    },
