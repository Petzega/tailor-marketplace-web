            { "id": "m-ca-1", "name": "waMessage", "value": "=❌ Hola {{ $json.customerName }}, lamentamos informarte que tu orden *{{ $json.orderId }}* ha sido *cancelada*.\n\nSi no solicitaste la cancelación o tienes dudas, escríbenos y un asesor te atenderá pronto.\n\n¡Gracias por tu comprensión! 🙏", "type": "string" },
