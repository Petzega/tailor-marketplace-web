    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "m-c-1", "name": "waMessage", "value": "=📦 ¡Hola {{ $json.customerName }}! Tu pedido *{{ $json.orderId }}* está *completado*.\n\nPuedes recogerlo en tienda o ya fue enviado según tu método de entrega. 🚚\n\nSi tienes dudas, responde este mensaje. ¡Gracias! 🙏", "type": "string" },
            { "id": "m-c-2", "name": "phone", "value": "={{ $json.customerPhone }}", "type": "string" },
            { "id": "m-c-3", "name": "orderId", "value": "={{ $json.orderId }}", "type": "string" },
