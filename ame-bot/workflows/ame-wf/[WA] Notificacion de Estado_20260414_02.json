    {
      "parameters": {
        "jsCode": "// 🔐 Validar Bearer token + campos requeridos\nconst authHeader = $json.headers['authorization'] || '';\nconst expected = $env.WEBHOOK_SECRET || '';\nif (!expected) throw new Error('WEBHOOK_SECRET not configured in n8n env vars');\nif (authHeader !== `Bearer ${expected}`) throw new Error('Unauthorized: Invalid webhook secret');\n\nconst { orderId, newStatus, customerPhone, customerName, total, previousStatus } = $json.body;\nif (!orderId || !newStatus || !customerPhone) throw new Error(`Missing fields: orderId=${orderId}, newStatus=${newStatus}, customerPhone=${customerPhone}`);\n\nreturn [{ json: { orderId, newStatus, previousStatus: previousStatus || 'PENDING', customerPhone, customerName: customerName || 'Cliente', total: total || 0 } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [224, 0],
      "id": "wf3-node-02-validate",
      "name": "Validar Token y Payload (Code)"
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "loose", "version": 3 },
                "conditions": [{ "id": "sw-ip", "leftValue": "={{ $json.newStatus }}", "rightValue": "IN_PROGRESS", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "IN_PROGRESS"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "loose", "version": 3 },
                "conditions": [{ "id": "sw-comp", "leftValue": "={{ $json.newStatus }}", "rightValue": "COMPLETED", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "COMPLETED"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "loose", "version": 3 },
                "conditions": [{ "id": "sw-canc", "leftValue": "={{ $json.newStatus }}", "rightValue": "CANCELLED", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "CANCELLED"
            }
          ]
        },
        "options": { "fallbackOutput": "extra" }
      },
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [448, 0],
      "id": "wf3-node-03-switch",
      "name": "Switch por Estado"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "m-ip-1", "name": "waMessage", "value": "=✅ ¡Hola {{ $json.customerName }}! Tu pago ha sido *validado* por nuestro equipo. 🎉\n\nTu orden *{{ $json.orderId }}* está ahora *en preparación*.\n\nTotal: *S/ {{ $json.total }}*\n\nTe avisaremos cuando esté lista. ¡Gracias por confiar en The Tailor Marketplace! 🧵", "type": "string" },
            { "id": "m-ip-2", "name": "phone", "value": "={{ $json.customerPhone }}", "type": "string" },
            { "id": "m-ip-3", "name": "orderId", "value": "={{ $json.orderId }}", "type": "string" },
            { "id": "m-ip-4", "name": "newStatus", "value": "={{ $json.newStatus }}", "type": "string" }
          ]
        }, "options": {}
      },
