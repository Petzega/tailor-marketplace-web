generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Float

  // 💡 Mantenemos este como "Stock Total" para no romper el catálogo actual
  stock Int @default(0)

  imageUrl String?
  category String  @default("READY_MADE")

  gender       String?
  clothingType String?
  ageGroup     String? @default("ADULT") // 👈 NUEVO: Rango de edad (ADULT, KIDS, BABY)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sku       String   @unique @default(cuid())

  gallery    ProductImage[]
  sizes      ProductSize[]
  orderItems OrderItem[] // Relación inversa para saber en qué órdenes está este producto
}

model ProductSize {
  id    String @id @default(cuid())
  size  String // Ej: "S", "M", "L", "XL", "32", "34"
  stock Int    @default(0) // El stock real de ESTA talla

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Esto evita que por error crees dos veces la talla "M" para el mismo producto
  @@unique([productId, size])
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// 👇 NUEVOS MODELOS PARA GESTIÓN DE ÓRDENES Y N8N

model Order {
  id             String @id @default(cuid()) // Número de orden base (ej: clr5a1...)
  status         String @default("PENDING") // PENDING, IN_PROGRESS, CANCELLED, COMPLETED
  validationCode String @unique // Código secreto de 6 letras/números para el agente n8n

  // Datos del Cliente
  customerName     String
  customerPhone    String
  customerDocType  String @default("DNI") // "DNI", "RUC", "CE", "PASAPORTE"
  customerDocument String // El número ingresado por el usuario

  // Datos Logísticos
  deliveryMethod String // "STORE", "DELIVERY"
  address        String? // Opcional si es "STORE"
  reference      String?

  // Finanzas
  paymentMethod String // YAPE, PLIN, TRANSFERENCIA, EFECTIVO
  subtotal      Float
  deliveryCost  Float  @default(0)
  total         Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items      OrderItem[] // Los productos que componen esta orden
  customer   Customer?   @relation(fields: [customerId], references: [id])
  customerId String?
}

model OrderItem {
  id String @id @default(cuid())

  // Guardamos un snapshot del precio en el momento de la compra
  // Si el precio del producto cambia a futuro, esto no altera la orden histórica.
  price    Float
  quantity Int     @default(1)
  size     String? // Ej: "S", "M" (Puede ser null si el producto no tiene tallas)

  // Relaciones
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model Customer {
  id             String  @id @default(cuid())
  docType        String  @default("DNI")
  documentNumber String  @unique // 👈 Identificador principal para asociar
  name           String
  phone          String?
  address        String?

  // Perfil de sastrería
  measurements String? // 👈 Aquí guardaremos sus medidas corporales (JSON o texto)
  notes        String? // Preferencias del cliente

  orders   Order[] // Historial de compras en tienda
  services Service[] // Historial de servicios de sastrería

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id     String @id @default(cuid())
  status String @default("PENDING") // PENDING, FITTING (Prueba), READY (Listo), DELIVERED (Entregado)

  serviceType  String // Ej: "Entalle de vestido", "Basta de pantalón", "Confección a medida"
  description  String // Detalles de lo que se debe hacer
  serviceNotes String? // Apuntes específicos para este servicio

  // Finanzas del servicio
  price   Float
  deposit Float @default(0) // Adelanto dejado por el cliente
  balance Float // Saldo pendiente (price - deposit)

  // Cronograma
  receptionDate DateTime  @default(now())
  fittingDate   DateTime? // Fecha de prueba (opcional)
  deliveryDate  DateTime? // Fecha programada de entrega final

  // Relación con el Cliente
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String // El ID del usuario de Clerk que hizo la acción
  userEmail  String // Opcional: El correo para leerlo más fácil en tu panel
  action     String // Acción. Ej: "UPDATE_STATUS", "UPDATE_FINANCE"
  entityType String // Tabla afectada. Ej: "SERVICE", "PRODUCT"
  entityId   String // El ID del registro modificado (ej: TK-260401001)
  details    String? // Contexto. Ej: "Cambió estado a DELIVERED"
  createdAt  DateTime @default(now())

  // Índices para que las búsquedas del historial sean súper rápidas
  @@index([entityId])
  @@index([userId])
}
