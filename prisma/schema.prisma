generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Float

  // 💡 Mantenemos este como "Stock Total" para no romper el catálogo actual
  stock Int @default(0)

  imageUrl String?
  category String  @default("READY_MADE")

  gender       String?
  clothingType String?
  ageGroup     String? @default("ADULT") // 👈 NUEVO: Rango de edad (ADULT, KIDS, BABY)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sku       String   @unique @default(cuid())

  gallery ProductImage[]
  sizes   ProductSize[] // Relación con las tallas específicas

  orderItems OrderItem[]
}

// 👇 NUEVA TABLA: Para manejar el stock independiente por talla
model ProductSize {
  id    String @id @default(cuid())
  size  String // Ej: "S", "M", "L", "XL", "32", "34"
  stock Int    @default(0) // El stock real de ESTA talla

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Esto evita que por error crees dos veces la talla "M" para el mismo producto
  @@unique([productId, size])
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ==========================================
// 📦 SISTEMA DE ÓRDENES Y VENTAS
// ==========================================

enum OrderStatus {
  PENDING
  IN_PROCESS
  DELIVERED_STORE
  DELIVERED_DELIVERY
  CANCELLED
}

model Order {
  id            String      @id @default(cuid())
  shortId       String      @unique // Código visible para el cliente: "ORD-12345"
  token         String      @unique // Token de seguridad para el Enlace Mágico

  // Datos del Cliente
  customerName      String
  customerPhone     String
  customerAddress   String?   // Opcional porque puede ser recojo en tienda
  customerReference String?   // Opcional

  // Detalles del Envío y Pago
  deliveryMethod    String    // Ej: "STORE" o "DELIVERY"
  paymentMethod     String    // Ej: "Yape", "Plin", "Efectivo"

  // Totales
  subtotal          Float
  deliveryCost      Float     @default(0)
  total             Float
  status            OrderStatus @default(PENDING)

  items             OrderItem[] // Los productos de esta orden

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Relación opcional con el producto del catálogo (puede ser null si el producto fue eliminado)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  quantity  Int
  price     Float   // Congelamos el precio al momento de la compra
  size      String? // Guardamos qué talla eligió
}