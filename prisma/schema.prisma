generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  stock       Int      @default(0)
  imageUrl    String? // 👈 Esta se queda como la foto principal (Miniatura)
  category    String   @default("READY_MADE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sku         String   @unique @default(cuid())

  // 👇 NUEVO: Relación con la galería de imágenes extra
  gallery ProductImage[]
}

// 👇 NUEVO: Tabla para las fotos secundarias del producto
model ProductImage {
  id        String   @id @default(cuid())
  url       String // La URL de la foto extra
  productId String // El ID del producto al que pertenece
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
